{
  "name": "forgewire-fabric",
  "displayName": "ForgeWire Fabric",
  "description": "Dispatch tasks to a ForgeWire Fabric compute mesh: signed envelopes, scope-bound capability tokens, live stream output. Run a hub or runner from inside VS Code on Windows, macOS, or Linux.",
  "version": "0.1.18",
  "publisher": "DigitalHallucinations",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "forgewire-fabric",
    "distributed",
    "cluster",
    "task-dispatch",
    "ai-agents",
    "remote-execution"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DigitalHallucinations/forgewire-fabric.git",
    "directory": "vscode"
  },
  "homepage": "https://github.com/DigitalHallucinations/forgewire-fabric",
  "bugs": {
    "url": "https://github.com/DigitalHallucinations/forgewire-fabric/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "ForgeWire Fabric",
      "properties": {
        "forgewireFabric.hubUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the ForgeWire hub (e.g. http://hub.local:8765). Leave empty to be prompted on first connect. When forgewireFabric.hubCandidates is non-empty this acts as an implicit additional candidate at priority 100."
        },
        "forgewireFabric.hubCandidates": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["url"],
            "properties": {
              "url": { "type": "string", "description": "Candidate hub URL." },
              "label": { "type": "string", "description": "Friendly label for the sidebar." },
              "priority": { "type": "number", "default": 100, "description": "Lower = preferred. Probed in ascending order." }
            }
          },
          "markdownDescription": "Ordered list of hub candidates for failover. The extension probes each candidate in priority order and uses the first reachable one as the active hub. Example:\n```\n[\n  { \"url\": \"http://10.120.81.95:8765\", \"label\": \"OptiPlex (always-on)\", \"priority\": 1 },\n  { \"url\": \"http://10.120.81.50:8765\", \"label\": \"Dell\", \"priority\": 2 }\n]\n```"
        },
        "forgewireFabric.hubPin": {
          "type": "string",
          "default": "",
          "description": "Manual override: when set, the extension dispatches to this URL only and does not probe candidates. Use the *Pin to Hub…* command to set this. Clear with *Unpin Hub*."
        },
        "forgewireFabric.hubName": {
          "type": "string",
          "default": "",
          "description": "Friendly display name for the hub (shown in the sidebar and status bar). Purely cosmetic — no effect on hub identity or auth."
        },
        "forgewireFabric.runnerAliases": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "Map of runner_id -> friendly alias. Used as the runner label in the sidebar."
        },
        "forgewireFabric.hubToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token for the hub. **Treat as a secret** \u2014 prefer SecretStorage via the *ForgeWire: Set Hub Token* command."
        },
        "forgewireFabric.hubTokenFile": {
          "type": "string",
          "default": "",
          "description": "Path to a file containing the hub bearer token. Used when forgewire.hubToken is empty. Defaults to ~/.forgewire/hub.token when present."
        },
        "forgewireFabric.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python interpreter used to install / launch the forgewire CLI. Empty = auto-detect (uses python.defaultInterpreterPath, then 'python3', then 'python')."
        },
        "forgewireFabric.refreshIntervalSeconds": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "description": "How often to refresh the runners and tasks tree views."
        },
        "forgewireFabric.approvals.ageBadgeHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "Show an aged-approval warning badge after this many hours pending."
        },
        "forgewireFabric.autoStartHubPort": {
          "type": "number",
          "default": 8765,
          "description": "Default port used by 'ForgeWire: Start Hub Here'."
        },
        "forgewireFabric.cluster.repoRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Filesystem path to the `forgewire-fabric` checkout containing `config/cluster.yaml` and `scripts/dr/`. Empty = auto-detect by walking up from the active workspace folder. Required only if you keep the repo outside any open workspace."
        },
        "forgewireFabric.cluster.preferredNode": {
          "type": "string",
          "default": "",
          "description": "Override cluster.yaml's preferred_node for this machine when running DR / chaos installers from this UI. Empty = use cluster.yaml."
        },
        "forgewireFabric.dr.backup.cadenceMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "How often the rqlite backup task runs. 0 = use cluster.yaml backups.cadence_minutes (5)."
        },
        "forgewireFabric.dr.backup.retentionHours": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "How long to keep rqlite backup snapshots. 0 = use cluster.yaml backups.retention_hours (24)."
        },
        "forgewireFabric.dr.chaos.cadenceMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "How often the chaos drill task runs (24h = 1440). 0 = use cluster.yaml chaos.cadence_minutes (1440). **Lower values WILL show up as latency spikes on the hub.**"
        },
        "forgewireFabric.dr.chaos.drills": {
          "type": "string",
          "default": "",
          "markdownDescription": "Comma-separated drill list. Empty = use cluster.yaml `chaos.drills`. Available: `kill-leader`, `lose-quorum`, `partition-recovery` (manual; touches Windows Firewall)."
        },
        "forgewireFabric.dr.chaos.retentionDays": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "How many days of chaos JSONL logs to keep. 0 = use cluster.yaml chaos.retention_days (30)."
        },
        "forgewireFabric.dr.chaos.principal": {
          "type": "string",
          "enum": ["SYSTEM", "user"],
          "default": "SYSTEM",
          "markdownDescription": "Windows principal the chaos scheduled task runs as. **SYSTEM** is recommended (no UAC prompts, full service-control rights). Choose **user** only if you cannot provision SSH keys for SYSTEM and need the task to inherit your user's `%USERPROFILE%\\.ssh` for cross-host drills."
        },
        "forgewireFabric.dr.chaos.force": {
          "type": "boolean",
          "default": false,
          "description": "Bypass the single-driver guard when installing the chaos task on a host whose preferred_node differs from cluster.yaml chaos.driver_node. Leave false unless you know what you're doing."
        }
      }
    },
    "commands": [
      {
        "command": "forgewireFabric.installCli",
        "title": "Install / Update CLI (pip install forgewire-fabric)",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.connectHub",
        "title": "Connect to Hub\u2026",
        "category": "ForgeWire Fabric",
        "icon": "$(plug)"
      },
      {
        "command": "forgewireFabric.setToken",
        "title": "Set Hub Token\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.disconnect",
        "title": "Disconnect",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.startHubHere",
        "title": "Start Hub Here\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.startRunnerHere",
        "title": "Start Runner Here\u2026",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.dispatchTask",
        "title": "Dispatch Task\u2026",
        "category": "ForgeWire Fabric",
        "icon": "$(rocket)"
      },
      {
