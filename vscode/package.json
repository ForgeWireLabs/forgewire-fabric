          "command": "forgewire.copyApprovalReference",
          "when": "false"
        },
        {
          "command": "forgewire.redispatchTask",
          "when": "view == forgewire.tasks && viewItem =~ /^taskHistory\\.(failed|cancelled|timed_out)$/",
          "group": "inline@1"
        },
        {
          "command": "forgewire.dismissTask",
          "when": "view == forgewire.tasks && viewItem =~ /^taskHistory\\./",
          "group": "inline@2"
        },
        {
          "command": "forgewire.cancelStaleTask",
          "when": "view == forgewire.tasks && viewItem =~ /^task\\.[a-z]+\\.stale$/",
          "group": "inline@1"
        },
        {
          "command": "forgewire.redispatchTask",
          "when": "view == forgewire.tasks && viewItem =~ /^task\\.[a-z]+\\.failed$/",
          "group": "inline@1"
        },
        {
          "command": "forgewire.pauseRunner"
        },
        {
          "command": "forgewire.resumeRunner"
        },
        {
          "command": "forgewire.restartRunnerService"
        },
        {
          "command": "forgewire.startRunnerService"
        },
        {
          "command": "forgewire.stopRunnerService"
        },
        {
          "command": "forgewire.pinHub"
        },
        {
          "command": "forgewire.unpinHub"
        },
        {
          "command": "forgewire.promoteHub"
        },
        {
          "command": "forgewire.demoteHub"
        },
        {
          "command": "forgewire.editHubCandidates"
        },
        {
          "command": "forgewire.dr.installBackupTask"
        },
        {
          "command": "forgewire.dr.installChaosTask"
        },
        {
          "command": "forgewire.dr.provisionSshForSystem"
        },
        {
          "command": "forgewire.dr.runChaosNow"
        },
        {
          "command": "forgewire.dr.tailLastChaosLog"
        },
        {
          "command": "forgewire.dr.openClusterYaml"
        },
        {
          "command": "forgewire.dr.openSettings"
        },
        {
          "command": "forgewire.redispatchTask",
          "title": "Redispatch Task",
          "category": "ForgeWire",
          "icon": "$(redo)"
        },
        {
          "command": "forgewire.dismissTask",
          "title": "Dismiss from History",
          "category": "ForgeWire",
          "icon": "$(close)"
        },
        {
          "command": "forgewire.cancelStaleTask",
          "title": "Cancel Stale Task",
          "category": "ForgeWire",
          "icon": "$(trash)"
        }
      ]
    }
