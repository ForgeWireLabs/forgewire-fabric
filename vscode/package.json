        "category": "ForgeWire Fabric",
        "icon": "$(stop-circle)"
      },
      {
        "command": "forgewireFabric.showTask",
        "title": "Show Task",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.approveApproval",
        "title": "Approve Approval",
        "category": "ForgeWire Fabric",
        "icon": "$(check)"
      },
      {
        "command": "forgewireFabric.denyApproval",
        "title": "Deny Approval",
        "category": "ForgeWire Fabric",
        "icon": "$(circle-slash)"
      },
      {
        "command": "forgewireFabric.deferApproval",
        "title": "Snooze Approval...",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-pause)"
      },
      {
        "command": "forgewireFabric.showDeferredApprovals",
        "title": "Show Snoozed Approvals",
        "category": "ForgeWire Fabric",
        "icon": "$(eye)"
      },
      {
        "command": "forgewireFabric.examineApproval",
        "title": "Examine Approval",
        "category": "ForgeWire Fabric",
        "icon": "$(inspect)"
      },
      {
        "command": "forgewireFabric.copyApprovalReference",
        "title": "Copy Approval ID / Envelope Hash",
        "category": "ForgeWire Fabric",
        "icon": "$(copy)"
      },
      {
        "command": "forgewireFabric.copyToken",
        "title": "Copy Hub Token to Clipboard",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.generateToken",
        "title": "Generate New Hub Token",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.openSettings",
        "title": "Open Settings…",
        "category": "ForgeWire Fabric",
        "icon": "$(gear)"
      },
      {
        "command": "forgewireFabric.renameHub",
        "title": "Rename Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(edit)"
      },
      {
        "command": "forgewireFabric.renameHost",
        "title": "Rename Host…",
        "category": "ForgeWire Fabric",
        "icon": "$(edit)"
      },
      {
        "command": "forgewireFabric.renameRunner",
        "title": "Rename Runner Alias…",
        "category": "ForgeWire Fabric",
        "icon": "$(edit)"
      },
      {
        "command": "forgewireFabric.pauseRunner",
        "title": "Pause Runner (drain)",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-pause)"
      },
      {
        "command": "forgewireFabric.resumeRunner",
        "title": "Resume Runner",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-start)"
      },
      {
        "command": "forgewireFabric.restartRunnerService",
        "title": "Restart Runner Service (local)",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-restart)"
      },
      {
        "command": "forgewireFabric.startRunnerService",
        "title": "Start Runner Service (local)",
        "category": "ForgeWire Fabric"
      },
      {
        "command": "forgewireFabric.stopRunnerService",
        "title": "Stop Runner Service (local)",
        "category": "ForgeWire Fabric",
        "icon": "$(debug-stop)"
      },
      {
        "command": "forgewireFabric.pinHub",
        "title": "Pin to Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(pin)"
      },
      {
        "command": "forgewireFabric.unpinHub",
        "title": "Unpin Hub",
        "category": "ForgeWire Fabric",
        "icon": "$(pinned)"
      },
      {
        "command": "forgewireFabric.promoteHub",
        "title": "Promote This Node to Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(arrow-up)"
      },
      {
        "command": "forgewireFabric.demoteHub",
        "title": "Demote Active Hub…",
        "category": "ForgeWire Fabric",
        "icon": "$(arrow-down)"
      },
      {
        "command": "forgewireFabric.editHubCandidates",
        "title": "Edit Hub Candidates…",
        "category": "ForgeWire Fabric",
        "icon": "$(list-tree)"
      },
      {
        "command": "forgewireFabric.dr.installBackupTask",
        "title": "DR: Install rqlite Backup Task on This Host",
        "category": "ForgeWire Fabric",
        "icon": "$(database)"
      },
      {
        "command": "forgewireFabric.dr.installChaosTask",
        "title": "DR: Install Chaos Drill Task on This Host",
        "category": "ForgeWire Fabric",
        "icon": "$(zap)"
      },
      {
        "command": "forgewireFabric.dr.provisionSshForSystem",
        "title": "DR: Provision SSH Key for SYSTEM (cross-host chaos)",
        "category": "ForgeWire Fabric",
        "icon": "$(key)"
      },
      {
        "command": "forgewireFabric.dr.runChaosNow",
        "title": "DR: Run Chaos Drill Now",
        "category": "ForgeWire Fabric",
        "icon": "$(play)"
      },
      {
        "command": "forgewireFabric.dr.tailLastChaosLog",
        "title": "DR: Open Last Chaos Drill Log",
        "category": "ForgeWire Fabric",
        "icon": "$(go-to-file)"
      },
      {
        "command": "forgewireFabric.dr.openClusterYaml",
        "title": "DR: Open cluster.yaml",
        "category": "ForgeWire Fabric",
        "icon": "$(json)"
      },
      {
        "command": "forgewireFabric.dr.openSettings",
        "title": "DR: Open Cluster & Chaos Settings",
        "category": "ForgeWire Fabric",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forgewireFabric",
          "title": "ForgeWire Fabric",
          "icon": "media/sidebar.svg"
        }
      ]
    },
    "views": {
    "forgewireFabric": [
        {
          "id": "forgewireFabric.hub",
          "name": "Hub",
          "icon": "$(plug)",
          "contextualTitle": "ForgeWire Fabric Hub"
        },
        {
          "id": "forgewireFabric.hosts",
          "name": "Hosts",
          "icon": "$(device-desktop)",
          "contextualTitle": "ForgeWire Fabric Hosts"
        },
        {
          "id": "forgewireFabric.tasks",
          "name": "Tasks",
          "icon": "$(checklist)",
          "contextualTitle": "ForgeWire Fabric Tasks"
        },
        {
          "id": "forgewireFabric.approvals",
          "name": "Approvals",
          "icon": "$(verified)",
          "contextualTitle": "ForgeWire Fabric Approvals"
        },
        {
          "id": "forgewireFabric.audit",
          "name": "Audit log",
          "icon": "$(history)",
          "contextualTitle": "ForgeWire Fabric Audit Log"
        },
        {
          "id": "forgewireFabric.secrets",
          "name": "Secrets",
          "icon": "$(lock)",
          "contextualTitle": "ForgeWire Fabric Secrets"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "forgewireFabric.hub",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)\n\n[Open Settings](command:forgewireFabric.openSettings)\n\n[Start a Hub Locally](command:forgewireFabric.startHubHere)",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.hosts",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)\n\n[Start a Hub Locally](command:forgewireFabric.startHubHere)",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.tasks",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.approvals",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.audit",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)",
        "when": "!forgewireFabric.connected"
      },
      {
        "view": "forgewireFabric.secrets",
        "contents": "No hub connection.\n\n[Connect to Hub](command:forgewireFabric.connectHub)",
        "when": "!forgewireFabric.connected"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forgewireFabric.refresh",
          "when": "view == forgewireFabric.tasks || view == forgewireFabric.hub || view == forgewireFabric.hosts || view == forgewireFabric.approvals || view == forgewireFabric.audit || view == forgewireFabric.secrets",
          "group": "navigation@1"
        },
        {
          "command": "forgewireFabric.openSettings",
          "when": "view == forgewireFabric.hub",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.dispatchTask",
          "when": "view == forgewireFabric.tasks",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.showDeferredApprovals",
          "when": "view == forgewireFabric.approvals && forgewireFabric.hasDeferredApprovals",
          "group": "navigation@2"
        },
        {
          "command": "forgewireFabric.connectHub",
          "when": "view == forgewireFabric.hosts",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "forgewireFabric.renameHub",
          "when": "view == forgewireFabric.hub && viewItem == hub.name",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.pinHub",
          "when": "view == forgewireFabric.hub && viewItem == hub.url.auto",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.unpinHub",
          "when": "view == forgewireFabric.hub && viewItem == hub.url.pinned",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.editHubCandidates",
          "when": "view == forgewireFabric.hub && viewItem == hub.candidates",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.renameHost",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^hosts\\.host\\./",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.renameRunner",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^runner\\./",
          "group": "inline@1.5"
        },
        {
          "command": "forgewireFabric.pauseRunner",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^runner\\.online\\./",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.resumeRunner",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^runner\\.draining\\./",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.restartRunnerService",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^runner\\.[a-z]+\\.local$/",
          "group": "inline@3"
        },
        {
          "command": "forgewireFabric.stopRunnerService",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^runner\\.[a-z]+\\.local$/",
          "group": "runner@2"
        },
        {
          "command": "forgewireFabric.startRunnerService",
          "when": "view == forgewireFabric.hosts && viewItem =~ /^runner\\.offline\\.local$/",
          "group": "runner@1"
        },
        {
          "command": "forgewireFabric.streamTask",
          "when": "view == forgewireFabric.tasks && viewItem =~ /^task\\./",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.cancelTask",
          "when": "view == forgewireFabric.tasks && viewItem =~ /^task\\./",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.showTask",
          "when": "view == forgewireFabric.tasks && viewItem =~ /^task\\./"
        },
        {
          "command": "forgewireFabric.approveApproval",
          "when": "view == forgewireFabric.approvals && viewItem == approval.pending",
          "group": "inline@1"
        },
        {
          "command": "forgewireFabric.denyApproval",
          "when": "view == forgewireFabric.approvals && viewItem == approval.pending",
          "group": "inline@2"
        },
        {
          "command": "forgewireFabric.deferApproval",
          "when": "view == forgewireFabric.approvals && viewItem == approval.pending",
          "group": "inline@3"
        },
        {
          "command": "forgewireFabric.examineApproval",
          "when": "view == forgewireFabric.approvals && viewItem =~ /^approval\\./",
          "group": "inline@4"
        },
        {
          "command": "forgewireFabric.copyApprovalReference",
          "when": "view == forgewireFabric.approvals && viewItem =~ /^approval\\./",
          "group": "inline@5"
        }
      ],
      "commandPalette": [
        {
          "command": "forgewireFabric.streamTask"
        },
        {
          "command": "forgewireFabric.cancelTask"
        },
        {
          "command": "forgewireFabric.showTask"
        },
        {
          "command": "forgewireFabric.approveApproval",
          "when": "false"
        },
        {
          "command": "forgewireFabric.denyApproval",
          "when": "false"
        },
        {
          "command": "forgewireFabric.deferApproval",
          "when": "false"
        },
        {
          "command": "forgewireFabric.examineApproval",
          "when": "false"
        },
        {
          "command": "forgewireFabric.copyApprovalReference",
          "when": "false"
        },
        {
          "command": "forgewireFabric.pauseRunner"
        },
        {
          "command": "forgewireFabric.resumeRunner"
        },
        {
          "command": "forgewireFabric.restartRunnerService"
        },
        {
          "command": "forgewireFabric.startRunnerService"
        },
        {
          "command": "forgewireFabric.stopRunnerService"
        },
        {
          "command": "forgewireFabric.pinHub"
        },
        {
          "command": "forgewireFabric.unpinHub"
        },
        {
          "command": "forgewireFabric.promoteHub"
        },
        {
          "command": "forgewireFabric.demoteHub"
        },
        {
          "command": "forgewireFabric.editHubCandidates"
        },
        {
          "command": "forgewireFabric.dr.installBackupTask"
        },
        {
          "command": "forgewireFabric.dr.installChaosTask"
        },
        {
          "command": "forgewireFabric.dr.provisionSshForSystem"
        },
        {
          "command": "forgewireFabric.dr.runChaosNow"
        },
        {
          "command": "forgewireFabric.dr.tailLastChaosLog"
        },
        {
          "command": "forgewireFabric.dr.openClusterYaml"
        },
        {
          "command": "forgewireFabric.dr.openSettings"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.32.0"
  }
}
