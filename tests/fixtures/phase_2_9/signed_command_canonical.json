        "require_base_commit": false,
        "kind": "command",
        "max_cost_usd": null,
        "timestamp": 1700000000,
        "nonce": "abcdef1234567890",
        "loom_command": ["pytest", "-q", "tests/"],
        "loom_cwd": "/projects/forgewire",
        "loom_env_keys": [],
