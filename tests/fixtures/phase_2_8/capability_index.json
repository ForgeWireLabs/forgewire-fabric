            "prompts": [
              {"name": "persona:Researcher", "description": "Researcher persona", "arguments": []},
              {"name": "persona:Engineer", "description": "Engineer persona", "arguments": []}
            ]
          }
        ]
      },
      "expected_rows": [
        {"runner_id": "runner-combined-host", "capability_kind": "tool",   "name": "git__commit",        "source_server": "git",                "description": "Create a git commit"},
