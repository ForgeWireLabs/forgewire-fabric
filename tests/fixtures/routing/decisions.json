        ],
        "required_tools": [],
        "required_tags": [],
        "require_base_commit": false,
        "base_commit": ""
      },
      "runner": {
        "tenant": "tenant-a",
        "scope_prefixes": [
          "core/"
        ],
        "tools": [],
        "tags": [],
        "last_known_commit": null
      },
      "verdict": "accept"
    },
